# ─────────────────────────────────────────────────
# Voice AI Clinic Agent — Environment Configuration
# Copy this file to .env and fill in your secrets.
# NEVER commit the real .env to version control.
# ─────────────────────────────────────────────────

# ── Application ──────────────────────────────────
APP_NAME="Voice AI Clinic Agent"
APP_VERSION="2.0.0"
DEBUG=false
LOG_LEVEL=INFO

# ── Server ────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Database ─────────────────────────────────────
# SQLite (development)
DATABASE_URL=sqlite+aiosqlite:///./data/clinic.db
# PostgreSQL (production) — uncomment below
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/clinic_db

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=1800

# ── OpenAI / LLM ─────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ── Deepgram (Speech-to-Text) ─────────────────────
DEEPGRAM_API_KEY=your-deepgram-api-key-here
DEEPGRAM_MODEL=nova-2

# ── ElevenLabs (Text-to-Speech) ──────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2

# ── Translation ───────────────────────────────────
# LibreTranslate (self-hosted or public instance)
LIBRETRANSLATE_URL=https://libretranslate.com
LIBRETRANSLATE_API_KEY=your-libretranslate-key-here

# ── Celery Workers ────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Feature Flags ─────────────────────────────────
ENABLE_CAMPAIGNS=true
ENABLE_DOCTOR_RECOMMENDATION=true
ENABLE_BARGE_IN=true

# ── Latency Targets (ms) ─────────────────────────
TARGET_ASR_LATENCY_MS=150
TARGET_LLM_LATENCY_MS=200
TARGET_TTS_LATENCY_MS=100
